# E2E Test Environment
# Copy to .env and fill in values

# OpenCode free-tier API key (get one at https://opencode.ai)
OPENCODE_API_KEY=oc-your-key-here

# OpenCode API base URL (default works for most users)
# OPENCODE_BASE_URL=https://api.opencode.ai/v1

# Model to use for E2E tests (nano is fastest/cheapest)
# OPENCODE_MODEL=opencode/gpt-4.1-nano

# PiClaw instance URL to test against
PICLAW_E2E_URL=http://localhost:3000

# Internal secret for E2E auth bootstrap
PICLAW_INTERNAL_SECRET=your-instance-secret
